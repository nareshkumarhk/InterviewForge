# Copy this file to .env and fill in your values
# Never commit .env to git

# Required: OpenAI API key
OPENAI_API_KEY=sk-...

# Optional: override default model (default: gpt-4o)
# OPENAI_MODEL=gpt-4o-mini

# Optional: max transcript tokens to send per evaluation (default: 26000)
# TRANSCRIPT_TOKEN_BUDGET=26000
